<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="AJ Tools"
           Manufacturer="Arian Jahandarfard"
           Version="!(bind.property.Version)"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <Feature Id="MainFeature" Title="AJ Tools">
      <ComponentGroupRef Id="AJFilesGroup" />
      <ComponentGroupRef Id="AJRegistryGroup" />
    </Feature>

  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="AJTools" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AJFilesGroup" Directory="INSTALLFOLDER">
      <Component Id="AJDllComp" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="AJDll"
              Source="$(var.SourceDir)\Arian Jahandarfards MS Project Add-in\bin\Release\Arian Jahandarfards MS Project Add-in.dll"
              KeyPath="yes" />
      </Component>
      <Component Id="AJManifestComp" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <File Id="AJManifest"
              Source="$(var.SourceDir)\Arian Jahandarfards MS Project Add-in\bin\Release\Arian Jahandarfards MS Project Add-in.dll.manifest"
              KeyPath="yes" />
      </Component>
      <Component Id="AJVstoComp" Guid="E5F6A7B8-C9D0-1234-EF01-456789012345">
        <File Id="AJVsto"
              Source="$(var.SourceDir)\Arian Jahandarfards MS Project Add-in\bin\Release\Arian Jahandarfards MS Project Add-in.vsto"
              KeyPath="yes" />
      </Component>
      <Component Id="MSOfficeToolsComp" Guid="F6A7B8C9-D0E1-2345-F012-567890123456">
        <File Id="MSOfficeTools"
              Source="$(var.SourceDir)\Arian Jahandarfards MS Project Add-in\bin\Release\Microsoft.Office.Tools.Common.v4.0.Utilities.dll"
              KeyPath="yes" />
      </Component>
      <Component Id="NewtonsoftComp" Guid="A7B8C9D0-E1F2-3456-0123-678901234567">
        <File Id="NewtonsoftDll"
              Source="$(var.SourceDir)\Arian Jahandarfards MS Project Add-in\bin\Release\Newtonsoft.Json.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AJRegistryGroup" Directory="INSTALLFOLDER">
      <Component Id="AJRegComp" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123">
        <RegistryKey Root="HKLM"
                     Key="SOFTWARE\Microsoft\Office\MS Project\Addins\ArianJahandarfardsAddIn">
          <RegistryValue Name="Description"  Value="AJ Tools"        Type="string"  />
          <RegistryValue Name="FriendlyName" Value="AJ Tools"        Type="string"  />
          <RegistryValue Name="LoadBehavior" Value="3"               Type="integer" />
          <RegistryValue Name="Manifest"
                         Value="C:\Program Files (x86)\AJTools\Arian Jahandarfards MS Project Add-in.vsto|vstolocal"
                         Type="string" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
